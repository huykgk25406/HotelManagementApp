       <height>381</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">QScrollArea {
    border: none;
}
#scrollAreaWidgetContents {
    background-color: #D9D9D9;
}
/* 1. Thiết lập tổng thể thanh cuộn */
QScrollBar:vertical {
    border: none;
    background: #F2F2F2; /* Màu nền xám nhạt bạn đã chọn */
    width: 10px;         /* Làm thanh cuộn mảnh lại cho tinh tế */
    margin: 0px 0px 0px 0px;
}

/* 2. Phần cục lăn (Handle) */
QScrollBar::handle:vertical {
    background: #A6A6A6; /* Màu xanh nhạt thương hiệu của bạn */
    min-height: 30px;
    border-radius: 5px;  /* Bo tròn hai đầu cục lăn */
}

/* 3. Hiệu ứng khi di chuột vào cục lăn */
QScrollBar::handle:vertical:hover {
    background: #999999; /* Đổi sang xanh đậm UEL khi hover */
}

/* 4. Xóa bỏ hai nút mũi tên ở đầu và cuối (Làm kiểu hiện đại) */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

/* 5. Xóa vùng nền phía trên và dưới cục lăn khi nhấn vào */
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}</string>
     </property>
     <property name="widgetResizable">
      <bool>true</bool>
     </property>
