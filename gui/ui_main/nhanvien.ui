      <string notr="true">/* 1. Ẩn viền bao quanh toàn bộ bảng */
QTableWidget {
    border: none;
    gridline-color: #D9D9D9; /* Màu đường kẻ dọc ở giữa bạn muốn */
	background-color: #EBEBEB;
}

/* 2. Đảm bảo viền của các ô (item) không hiện lên ở mép ngoài */
QTableWidget::item {
    border: none;
    /* Bạn có thể thêm border-bottom nếu muốn có đường kẻ ngang */
    border-bottom: 1px solid #D9D9D9; 
	background-color: #EBEBEB;
}
QHeaderView::section:horizontal {
    background-color: #EBEBEB; /* Màu xám bạch kim bạn vừa hỏi */
    color: #4B4B54;            /* Màu chữ đậm để nổi bật tiêu đề */
    padding: 5px;
    border: 1px solid #D9D9D9;
    font-weight: bold;
}

/* 3. Chỉnh ô tiêu đề HÀNG (Ca sáng, Ca chiều...) */
QHeaderView::section:vertical {
    background-color: #F2F2F2; /* Màu xám nhạt hơn một chút */
    color: #757575;
	padding: 5px;
    border: 1px solid #D9D9D9;
}
QTableCornerButton::section {
    background-color: #F2F2F2; /* Màu xám bạch kim đồng bộ với tiêu đề cột */
    border: 1px solid #D9D9D9;  /* Viền xám để khớp với lưới của bảng */
}</string>
     </property>
